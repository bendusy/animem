{
  "schema_version": "1",
  "name": "example-extension",
  "default_library": "documents",
  "tokenizer": {
    "custom_terms": ["Project Alpha", "Review Packet"]
  },
  "card_rules": {
    "entity_terms": ["Example Entity", "Sample Team"],
    "document_type_patterns": [
      {
        "contains": "memo",
        "value": "memo"
      },
      {
        "contains": "decision record",
        "value": "decision_record"
      }
    ]
  },
  "promotion": {
    "candidate_type_mappings": [
      {
        "candidate_kind": "procedure",
        "experience_type": "procedure"
      },
      {
        "candidate_kind": "template",
        "experience_type": "template"
      },
      {
        "candidate_kind": "rule",
        "experience_type": "rule"
      }
    ],
    "source_id": "example-source",
    "context_scope": "example-workspace"
  }
}
