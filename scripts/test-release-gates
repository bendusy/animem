#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/animem-release-gates.XXXXXX")"
trap 'rm -rf "$tmp_dir"' EXIT

expect_fail() {
  local label="$1"
  shift
  if "$@" >/dev/null 2>&1; then
    printf 'unexpected success: %s\n' "$label" >&2
    exit 1
  fi
  printf 'PASS negative %s\n' "$label"
}

cp -R "$repo_root/scripts" "$tmp_dir/scripts"
cd "$tmp_dir"
git init -q
git config user.email test@example.invalid
git config user.name "Animem Gate Test"
printf '# temp animem\n' > README.md
git add README.md scripts

printf 'README.md\n' > manifest.txt
bash scripts/check-source-bundle-allowlist manifest.txt

printf 'README.md\0' > manifest-nul.txt
bash scripts/check-source-bundle-allowlist manifest-nul.txt

printf '.cargo_vcs_info.json\nCargo.lock\nCargo.toml.orig\n' > manifest-generated.txt
bash scripts/check-source-bundle-allowlist manifest-generated.txt

printf 'cache/private.json\n' > manifest-untracked-private.txt
expect_fail "source bundle untracked private path" \
  bash scripts/check-source-bundle-allowlist manifest-untracked-private.txt

mkdir -p cache
printf '{}\n' > cache/tracked.json
git add -f cache/tracked.json
printf 'cache/tracked.json\n' > manifest-tracked-private.txt
expect_fail "source bundle tracked private path" \
  bash scripts/check-source-bundle-allowlist manifest-tracked-private.txt
git reset -q -- cache/tracked.json
rm -f cache/tracked.json

printf '%s\n' "$(git rev-parse --show-toplevel)/README.md" > manifest-absolute-path.txt
expect_fail "source bundle absolute path" \
  bash scripts/check-source-bundle-allowlist manifest-absolute-path.txt

printf 'TOKEN=placeholder\n' > profile.env
git add -f profile.env
printf 'profile.env\n' > manifest-env-suffix.txt
expect_fail "source bundle env suffix" \
  bash scripts/check-source-bundle-allowlist manifest-env-suffix.txt
git reset -q -- profile.env
rm -f profile.env

printf 'debug placeholder\n' > local.db
git add -f local.db
printf 'local.db\n' > manifest-db-file.txt
expect_fail "source bundle db file" \
  bash scripts/check-source-bundle-allowlist manifest-db-file.txt
git reset -q -- local.db
rm -f local.db

mkdir -p scripts/__pycache__
printf 'bytecode placeholder\n' > scripts/__pycache__/redaction_policy.cpython-312.pyc
git add -f scripts/__pycache__/redaction_policy.cpython-312.pyc
printf 'scripts/__pycache__/redaction_policy.cpython-312.pyc\n' > manifest-pycache.txt
expect_fail "source bundle python bytecode cache" \
  bash scripts/check-source-bundle-allowlist manifest-pycache.txt
git reset -q -- scripts/__pycache__/redaction_policy.cpython-312.pyc
rm -rf scripts/__pycache__

package_list="$(mktemp "${TMPDIR:-/tmp}/animem-package-list.XXXXXX")"
(cd "$repo_root" && cargo package --allow-dirty --no-verify --list >"$package_list")
for required in \
  examples/provenance/README.md \
  examples/provenance/candidate-evidence.synthetic.json \
  examples/provenance/review-decision-event.synthetic.json \
  examples/provenance/schema-artifact-manifest.synthetic.json \
  scripts/check-redacted-event-payload \
  scripts/redaction_policy.py \
  scripts/test-redacted-event-payload; do
  if ! grep -Fx -q "$required" "$package_list"; then
    printf 'missing package entry: %s\n' "$required" >&2
    exit 1
  fi
done
rm -f "$package_list"

printf 'release gate regression passed\n'
